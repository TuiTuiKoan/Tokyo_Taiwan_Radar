# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DEEPL_API_KEY=your-deepl-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional: Sentry error monitoring (get DSN from sentry.io → Project Settings → Client Keys)
SENTRY_DSN=
# Optional: GitHub token for auto-creating scraper Issues from @Researcher agent
# Classic token with 'repo' scope, or fine-grained token with Issues: write
GITHUB_TOKEN=
